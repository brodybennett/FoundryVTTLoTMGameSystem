{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lotm/actor.system.schema.v1_1.json",
  "title": "LoTM Actor.system Schema v1.1",
  "type": "object",
  "required": [
    "identity",
    "attributes",
    "skills",
    "derived",
    "resources",
    "progression",
    "creation",
    "version"
  ],
  "properties": {
    "identity": {
      "type": "object",
      "required": ["tier"],
      "properties": {
        "pathwayId": {
          "type": "string",
          "pattern": "^$|^[a-z][a-z0-9_.-]*$"
        },
        "sequence": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 9
            },
            {
              "type": "null"
            }
          ]
        },
        "tier": {
          "type": "string",
          "enum": ["low", "mid", "high", "demigod", "angel", "god"]
        },
        "backgroundId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        }
      },
      "additionalProperties": false
    },
    "attributes": {
      "type": "object",
      "required": ["str", "dex", "wil", "con", "cha", "int", "luck"],
      "properties": {
        "str": { "$ref": "#/$defs/attributeStat" },
        "dex": { "$ref": "#/$defs/attributeStat" },
        "wil": { "$ref": "#/$defs/attributeStat" },
        "con": { "$ref": "#/$defs/attributeStat" },
        "cha": { "$ref": "#/$defs/attributeStat" },
        "int": { "$ref": "#/$defs/attributeStat" },
        "luck": { "$ref": "#/$defs/attributeStat" }
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_.-]*$": {
          "$ref": "#/$defs/skillEntry"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "derived": {
      "type": "object",
      "required": ["hpMax", "spiritMax", "sanityMax", "defenseShift", "initiativeTarget"],
      "properties": {
        "hpMax": { "type": "integer", "minimum": 1 },
        "spiritMax": { "type": "integer", "minimum": 0 },
        "sanityMax": { "type": "integer", "minimum": 1 },
        "defenseShift": { "type": "integer", "minimum": -20, "maximum": 25 },
        "initiativeTarget": { "type": "integer", "minimum": 1, "maximum": 95 }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "required": ["hp", "spirit", "corruption", "deathMarks", "deathSaves"],
      "properties": {
        "hp": { "type": "integer", "minimum": -99999, "maximum": 99999 },
        "spirit": { "type": "integer", "minimum": 0, "maximum": 99999 },
        "corruption": { "type": "number", "minimum": 0, "maximum": 100 },
        "deathMarks": { "type": "integer", "minimum": 0, "maximum": 3 },
        "deathSaves": { "type": "integer", "minimum": 0, "maximum": 3 }
      },
      "additionalProperties": false
    },
    "combat": {
      "type": "object",
      "required": ["armor", "cover", "encumbrancePenalty", "damageReduction", "actionBudget"],
      "properties": {
        "armor": { "type": "integer", "minimum": -20, "maximum": 40 },
        "cover": { "type": "integer", "minimum": 0, "maximum": 25 },
        "encumbrancePenalty": { "type": "integer", "minimum": 0, "maximum": 60 },
        "damageReduction": { "type": "integer", "minimum": 0, "maximum": 999 },
        "actionBudget": {
          "type": "object",
          "required": ["actions", "moves", "reactions", "bonusActions"],
          "properties": {
            "actions": { "type": "integer", "minimum": 0, "maximum": 5 },
            "moves": { "type": "integer", "minimum": 0, "maximum": 5 },
            "reactions": { "type": "integer", "minimum": 0, "maximum": 5 },
            "bonusActions": { "type": "integer", "minimum": 0, "maximum": 5 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "progression": {
      "type": "object",
      "required": ["gates"],
      "properties": {
        "gates": {
          "type": "object",
          "required": ["narrative", "economy", "stability"],
          "properties": {
            "narrative": { "type": "boolean" },
            "economy": { "type": "boolean" },
            "stability": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "attemptState": {
          "type": "string",
          "enum": ["idle", "preparing", "rolling", "resolved"]
        }
      },
      "additionalProperties": false
    },
    "creation": {
      "type": "object",
      "required": ["state", "completedSteps", "version"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["draft", "identity", "attributes", "skills", "pathway", "equipment", "complete"]
        },
        "completedSteps": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["identity", "attributes", "skills", "pathway", "equipment"]
          },
          "uniqueItems": true
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999
        }
      },
      "additionalProperties": false
    },
    "tracks": {
      "type": "object",
      "properties": {
        "investigationIP": { "type": "integer", "minimum": 0, "maximum": 99 },
        "actionLock": { "type": "integer", "minimum": 0, "maximum": 1 },
        "movementCheckPenalty": { "type": "integer", "minimum": -95, "maximum": 0 },
        "damageOutMultiplier": { "type": "number", "minimum": 0, "maximum": 10 },
        "incomingOffenseBonus": { "type": "integer", "minimum": -95, "maximum": 95 },
        "offensePenaltyVsSource": { "type": "integer", "minimum": -95, "maximum": 0 },
        "verbalLocked": { "type": "integer", "minimum": 0, "maximum": 1 },
        "markedBySourceBonus": { "type": "integer", "minimum": -95, "maximum": 95 },
        "isDowned": { "type": "integer", "minimum": 0, "maximum": 1 },
        "factions": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": -100,
            "maximum": 100
          }
        },
        "threatClocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/threatClock" }
        },
        "influence": {
          "type": "object",
          "patternProperties": {
            "^[a-z][a-z0-9_.-]*$": {
              "type": "integer",
              "minimum": -20,
              "maximum": 20
            }
          },
          "additionalProperties": false
        },
        "leverage": {
          "type": "object",
          "patternProperties": {
            "^[a-z][a-z0-9_.-]*$": {
              "type": "integer",
              "minimum": 0,
              "maximum": 20
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ritual": {
      "type": "object",
      "properties": {
        "instability": {
          "type": "integer",
          "minimum": 0,
          "maximum": 99
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "sceneUsesById": {
          "type": "object",
          "patternProperties": {
            "^[a-z][a-z0-9_.-]*$": {
              "type": "integer",
              "minimum": 0,
              "maximum": 99
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "details": {
      "type": "object",
      "properties": {
        "alignment": { "type": "string", "maxLength": 120 },
        "faith": { "type": "string", "maxLength": 120 },
        "gender": { "type": "string", "maxLength": 120 },
        "eyes": { "type": "string", "maxLength": 120 },
        "hair": { "type": "string", "maxLength": 120 },
        "skin": { "type": "string", "maxLength": 120 },
        "height": { "type": "string", "maxLength": 120 },
        "weight": { "type": "string", "maxLength": 120 },
        "age": { "type": "string", "maxLength": 120 },
        "ideal": { "type": "string", "maxLength": 1000 },
        "bond": { "type": "string", "maxLength": 1000 },
        "flaw": { "type": "string", "maxLength": 1000 },
        "trait": { "type": "string", "maxLength": 1000 },
        "appearance": { "type": "string", "maxLength": 2000 },
        "biography": {
          "type": "object",
          "required": ["value", "public"],
          "properties": {
            "value": { "type": "string" },
            "public": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "traits": {
      "type": "object",
      "properties": {
        "senses": { "$ref": "#/$defs/stringList" },
        "resistances": { "$ref": "#/$defs/stringList" },
        "immunities": { "$ref": "#/$defs/stringList" },
        "conditionImmunities": { "$ref": "#/$defs/stringList" },
        "vulnerabilities": { "$ref": "#/$defs/stringList" },
        "damageModification": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "version": {
      "type": "object",
      "required": ["schemaVersion"],
      "properties": {
        "schemaVersion": {
          "type": "integer",
          "const": 1
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "attributeStat": {
      "type": "object",
      "required": ["base", "temp"],
      "properties": {
        "base": { "type": "integer", "minimum": 0, "maximum": 100 },
        "temp": { "type": "integer", "minimum": -50, "maximum": 50 }
      },
      "additionalProperties": false
    },
    "skillEntry": {
      "type": "object",
      "required": ["linkedAttr", "rank", "misc"],
      "properties": {
        "linkedAttr": {
          "type": "string",
          "enum": ["str", "dex", "wil", "con", "cha", "int", "luck"]
        },
        "rank": {
          "type": "string",
          "enum": ["untrained", "familiar", "trained", "expert", "master", "legendary"]
        },
        "misc": {
          "type": "integer",
          "minimum": -50,
          "maximum": 50
        }
      },
      "additionalProperties": false
    },
    "threatClock": {
      "type": "object",
      "required": ["id", "label", "current", "max"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "current": {
          "type": "integer",
          "minimum": 0,
          "maximum": 99
        },
        "max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 99
        }
      },
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lotm/effect.schema.v1_1.json",
  "title": "LoTM Effect Schema v1.1",
  "type": "object",
  "required": [
    "id",
    "op",
    "sourceCategory",
    "target",
    "trigger",
    "applyPhase",
    "tickPhase",
    "durationRounds",
    "saveType",
    "saveTarget",
    "stackRule",
    "removeOn"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "op": {
      "type": "string",
      "enum": ["add", "mul", "set", "grantCondition", "cost"]
    },
    "path": {
      "type": "string",
      "pattern": "^system\\.[a-zA-Z0-9_.]+$"
    },
    "value": {
      "type": "number"
    },
    "conditionId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "sourceCategory": {
      "type": "string",
      "enum": ["ability", "ritual", "artifact", "condition", "item", "environment", "other"]
    },
    "target": {
      "type": "string",
      "enum": ["self", "source", "ally", "enemy", "target", "area", "scene", "special"]
    },
    "trigger": {
      "type": "string",
      "enum": ["onUse", "onHit", "onDamaged", "onApply", "startOfTurn", "endOfTurn", "manual", "special"]
    },
    "stackGroup": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "oncePerTurn": {
      "type": "boolean"
    },
    "applyPhase": {
      "type": "string",
      "enum": ["immediate", "startOfTurn", "endOfTurn", "none"]
    },
    "tickPhase": {
      "type": "string",
      "enum": ["none", "startOfTurn", "endOfTurn"]
    },
    "durationRounds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 999
    },
    "saveType": {
      "type": "string",
      "enum": ["none", "str", "dex", "wil", "con", "cha", "int", "luck", "skill", "ritual"]
    },
    "saveTarget": {
      "type": "integer",
      "minimum": 0,
      "maximum": 95
    },
    "stackRule": {
      "type": "string",
      "enum": ["replace", "refresh", "stackLimited", "ignore"]
    },
    "maxStacks": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "removeOn": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["durationEnd", "saveSuccess", "sourceEnd", "dispel", "shortRest", "longRest"]
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "string",
      "maxLength": 500
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "op": {
            "const": "grantCondition"
          }
        }
      },
      "then": {
        "required": ["conditionId"]
      }
    },
    {
      "if": {
        "properties": {
          "op": {
            "enum": ["add", "mul", "set", "cost"]
          }
        }
      },
      "then": {
        "required": ["path", "value"]
      }
    },
    {
      "if": {
        "properties": {
          "saveType": {
            "const": "none"
          }
        }
      },
      "then": {
        "properties": {
          "saveTarget": {
            "const": 0
          }
        },
        "not": {
          "properties": {
            "removeOn": {
              "contains": {
                "const": "saveSuccess"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "saveType": {
            "enum": ["str", "dex", "wil", "con", "cha", "int", "luck", "skill", "ritual"]
          }
        }
      },
      "then": {
        "properties": {
          "saveTarget": {
            "minimum": 1,
            "maximum": 95
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "stackRule": {
            "const": "stackLimited"
          }
        }
      },
      "then": {
        "required": ["maxStacks"]
      }
    },
    {
      "if": {
        "properties": {
          "op": {
            "const": "cost"
          }
        }
      },
      "then": {
        "properties": {
          "value": {
            "minimum": 0
          }
        }
      }
    }
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lotm/content.rolltable.schema.v1_2.json",
  "title": "LoTM RollTable Content Source Schema v1.2",
  "type": "object",
  "required": [
    "id",
    "pack",
    "documentType",
    "name",
    "version",
    "minSystemVersion",
    "maxTestedSystemVersion",
    "dependencies",
    "segment",
    "formula",
    "results"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "pack": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "documentType": {
      "type": "string",
      "const": "RollTable"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "minSystemVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "maxTestedSystemVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_.-]*$"
      },
      "uniqueItems": true
    },
    "segment": {
      "type": "string",
      "enum": [
        "resources",
        "abilities",
        "rituals",
        "artifacts",
        "corruption",
        "encounters"
      ]
    },
    "formula": {
      "type": "string",
      "pattern": "^1d[1-9][0-9]*$"
    },
    "triggerTags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_.-]*$"
      },
      "uniqueItems": true
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/result"
      }
    }
  },
  "$defs": {
    "result": {
      "type": "object",
      "required": ["text", "weight"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "weight": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999
        },
        "img": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
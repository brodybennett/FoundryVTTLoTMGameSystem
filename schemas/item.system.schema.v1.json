{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lotm/item.system.schema.v1.json",
  "title": "LoTM Item.system Schema v1",
  "type": "object",
  "required": ["id", "schemaVersion", "name", "type"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "type": {
      "type": "string",
      "enum": [
        "pathway",
        "sequenceNode",
        "ability",
        "ritual",
        "artifact",
        "weapon",
        "armor",
        "consumable",
        "ingredient",
        "background",
        "conditionTemplate"
      ]
    },
    "pathwayId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9
    },
    "minSequence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9
    },
    "activation": {
      "type": "string",
      "enum": ["action", "reaction", "passive", "special"]
    },
    "resource": {
      "type": "string",
      "enum": ["spirit", "hp", "none", "item"]
    },
    "cost": {
      "type": "integer",
      "minimum": 0,
      "maximum": 999
    },
    "cooldown": {
      "type": "integer",
      "minimum": 0,
      "maximum": 999
    },
    "formulaKey": {
      "type": "string",
      "enum": [
        "check.attribute.v1",
        "check.skill.v1",
        "check.ritual.v1",
        "check.death.v1",
        "calc.derived.hp.v1",
        "calc.derived.spirit.v1",
        "calc.derived.sanity.v1",
        "calc.corruption.penalty.v1"
      ]
    },
    "effects": {
      "type": "array",
      "items": {
        "$ref": "effect.schema.v1.json"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_.-]*$"
      },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "minSystemVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "maxTestedSystemVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "requiresIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_.-]*$"
          },
          "uniqueItems": true
        }
      },
      "required": ["minSystemVersion", "maxTestedSystemVersion"],
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "ability"
          }
        }
      },
      "then": {
        "required": [
          "pathwayId",
          "sequence",
          "minSequence",
          "activation",
          "resource",
          "cost",
          "cooldown",
          "formulaKey",
          "effects"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "conditionTemplate"
          }
        }
      },
      "then": {
        "required": ["effects"]
      }
    }
  ],
  "additionalProperties": false
}
